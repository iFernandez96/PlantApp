{
  "name": "@plantapp/backend",
  "version": "0.0.0",
  "private": true,
  "description": "PlantApp backend — Node.js + TypeScript. Slice 1 scaffolding only; no production behavior yet.",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "lint": "eslint .",
    "test": "vitest run",
    "test:int": "vitest run --config vitest.integration.config.ts",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "validate-schemas": "ajv compile --spec=draft2020 --all-errors --strict=true -s '../shared-schemas/*.schema.json'"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "ajv-cli": "^5.0.0",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vitest": "^2.1.8"
  }
}
