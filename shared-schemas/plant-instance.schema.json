{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://plantapp.dev/schemas/plant-instance.schema.json",
  "title": "PlantInstance",
  "description": "A user's actual plant tied to a container and a garden space.",
  "type": "object",
  "additionalProperties": false,
  "required": ["id", "userId", "profileId", "containerId", "gardenSpaceId", "growthStage", "createdAt"],
  "properties": {
    "id": { "type": "string", "format": "uuid" },
    "userId": { "type": "string" },
    "profileId": { "type": "string" },
    "nickname": { "type": "string", "maxLength": 80 },
    "cultivar": { "type": "string", "maxLength": 80 },
    "containerId": { "type": "string", "format": "uuid" },
    "gardenSpaceId": { "type": "string", "format": "uuid" },
    "placement": {
      "type": "string",
      "enum": ["floor", "shelf", "railing", "hanging", "trellis", "vertical-rack", "windowsill"]
    },
    "placementHeightCm": { "type": "integer", "minimum": 0 },
    "acquiredAt": { "type": "string", "format": "date" },
    "plantedAt": { "type": "string", "format": "date" },
    "lastWateredAt": {
      "type": "string",
      "format": "date-time",
      "description": "Onboarding baseline for initial watering task. Later slices derive this from CareLogEvent history."
    },
    "growthStage": {
      "type": "string",
      "enum": ["seed", "seedling", "vegetative", "flowering", "fruiting", "dormant", "harvested"]
    },
    "supportRecorded": { "type": "boolean", "default": false },
    "notes": { "type": "string", "maxLength": 4000 },
    "photos": {
      "type": "array",
      "items": { "type": "string", "description": "object-storage key, never a URL" }
    },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
